@{
    ViewData["Title"] = "Orbit Curriculum Analyzer";
}

<div class="container mt-5">

    <h1 class="text-center mb-4">
        Orbit Curriculum Analyzer
    </h1>

    <div class="card p-4 shadow">

        <label class="mb-2">University Name</label>
        <input type="text"
               id="universityName"
               class="form-control mb-3"
               placeholder="e.g. NUML, FAST, COMSATS" />

        <label class="mb-2">Select PDF File</label>
        <input type="file"
               id="pdfFile"
               class="form-control mb-3"
               accept="application/pdf" />

        <button class="btn btn-primary w-100" onclick="parseCurriculum()">
            Parse Curriculum
        </button>

    </div>

    <div class="mt-4">

        <h4>Response</h4>

        <pre id="resultBox"
             class="border p-3 bg-light"
             style="min-height:250px; white-space:pre-wrap;"></pre>

    </div>

</div>

<script>

    async function parseCurriculum() {

        const fileInput = document.getElementById("pdfFile");
        const universityInput = document.getElementById("universityName");
        const resultBox = document.getElementById("resultBox");

        if (fileInput.files.length === 0) {
            alert("Please select a PDF file.");
            return;
        }

        if (!universityInput.value.trim()) {
            alert("Please enter university name.");
            return;
        }

        const formData = new FormData();

        formData.append("file", fileInput.files[0]);
        formData.append("universityName", universityInput.value);

        resultBox.textContent = "Parsing curriculum with Gemini AI...";

        try {

            const response = await fetch(
                "https://localhost:55593/api/curriculum/parse",
                {
                    method: "POST",
                    body: formData
                });

            if (!response.ok) {

                const errorText = await response.text();

                throw new Error(
                    `Server Error ${response.status}\n\n${errorText}`
                );
            }

            const data = await response.json();

            resultBox.textContent =
                JSON.stringify(data, null, 2);

        }
        catch (error) {

            console.error(error);

            resultBox.textContent =
                "Request Failed\n\n" + error.message;
        }
    }

</script>